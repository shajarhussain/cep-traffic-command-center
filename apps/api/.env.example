# ─── apps/api/.env.example ─────────────────────────────────────
# Copy to apps/api/.env and fill in. None of these values are
# required for the system to boot — fallback modes kick in when
# keys are missing. See EXTERNAL_APIS.md for free signup steps.

# ─── Server ─────────────────────────────────────────────────────
PORT=4000
WEB_ORIGIN=http://localhost:5173

# ─── Database (Prisma) ──────────────────────────────────────────
DATABASE_URL=file:../../prisma/dev.db

# ─── External APIs ──────────────────────────────────────────────
# TomTom Traffic API — free tier 2,500 calls/day, no card.
# Sign up at https://developer.tomtom.com/
TOMTOM_API_KEY=
TOMTOM_BASE_URL=https://api.tomtom.com

# Open-Meteo — no key, no signup. 10,000 calls/day free for non-commercial use.
# OPENMETEO_BASE_URL=https://api.open-meteo.com

# ─── Fine fallback defaults (used when no FinePolicy row matches) ─
# These are env-configurable so AlertService never embeds magic numbers.
DEFAULT_FINE_HIGH=5000
DEFAULT_FINE_MEDIUM=3000
DEFAULT_FINE_LOW=1500
DEFAULT_FINE_HIGH_THRESHOLD_KMH=30
DEFAULT_FINE_MEDIUM_THRESHOLD_KMH=15

# ─── Outbox relay (CLO 4 Scenario 3) ────────────────────────────
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=50
OUTBOX_RELAY_MAX_ATTEMPTS=5
